<Window
    x:Class="SaveStories.WinUI.Beta.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SaveStories.WinUI.Beta"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="using:SaveStories.WinUI.Beta.Pages"
    mc:Ignorable="d"
    Title="SaveStories Windows .beta">

    <Grid>
        <NavigationView
            x:Name="AppNav"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            PaneDisplayMode="LeftCompact"
            SelectionChanged="OnNavigationSelectionChanged">

            <NavigationView.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="SaveStories Windows .beta" />
                    <Border
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        Padding="10,4"
                        VerticalAlignment="Center"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="12">
                        <TextBlock Opacity="0.75" Text="0.6.2-beta" />
                    </Border>
                </Grid>
            </NavigationView.Header>

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Stories" Icon="Contact" Tag="stories" />
                <NavigationViewItem Content="Очередь профилей" Icon="Bullets" Tag="queue" />
                <NavigationViewItem Content="Reels" Icon="Video" Tag="reels" />
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Настройки" Icon="Setting" Tag="settings" />
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>
