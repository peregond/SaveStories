<Window
    x:Class="SaveMe.WinUI.Beta.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SaveMe.WinUI.Beta"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="using:SaveMe.WinUI.Beta.Pages"
    mc:Ignorable="d"
    Title="SaveMe Windows">

    <Grid Background="{ThemeResource AppWindowBackgroundBrush}">
        <NavigationView
            x:Name="AppNav"
            Background="Transparent"
            CompactPaneLength="56"
            IsBackButtonVisible="Collapsed"
            IsPaneOpen="True"
            IsSettingsVisible="False"
            OpenPaneLength="236"
            PaneDisplayMode="Left"
            SelectionChanged="OnNavigationSelectionChanged">

            <NavigationView.Header>
                <Grid Padding="0,0,8,0" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock
                            FontSize="20"
                            FontWeight="SemiBold"
                            Text="SaveMe Windows" />
                        <TextBlock
                            Opacity="0.65"
                            Style="{StaticResource AppSecondaryTextStyle}"
                            Text="Stories и Reels" />
                    </StackPanel>
                    <Border
                        Grid.Column="1"
                        Padding="10,4"
                        VerticalAlignment="Center"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse
                                x:Name="NodeStatusDot"
                                Width="8"
                                Height="8"
                                Fill="#FFF79939" />
                            <TextBlock FontWeight="SemiBold" Text="Node" />
                            <TextBlock x:Name="NodeStatusText" Opacity="0.75" Text="check" />
                        </StackPanel>
                    </Border>
                    <Border
                        Grid.Column="2"
                        Padding="10,4"
                        VerticalAlignment="Center"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse
                                x:Name="SessionStatusDot"
                                Width="8"
                                Height="8"
                                Fill="#FFF79939" />
                            <TextBlock FontWeight="SemiBold" Text="Session" />
                            <TextBlock x:Name="SessionStatusText" Opacity="0.75" Text="check" />
                        </StackPanel>
                    </Border>
                    <Button
                        x:Name="RefreshStatusButton"
                        Grid.Column="3"
                        Click="OnRefreshStatusClick"
                        ToolTipService.ToolTip="Проверить Node и Session">
                        <FontIcon FontSize="16" Glyph="&#xE72C;" />
                    </Button>
                    <Border
                        Grid.Column="4"
                        Padding="10,4"
                        VerticalAlignment="Center"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8">
                        <TextBlock x:Name="VersionBadgeText" Opacity="0.75" Text="0.0.0" />
                    </Border>
                </Grid>
            </NavigationView.Header>

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Stories" Tag="stories">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="📱" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Списочная" Tag="queue">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="📋" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Reels" Tag="reels">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="📹" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Сортировка" Tag="sorting">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="🗂️" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Настройки" Icon="Setting" Tag="settings" />
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>
