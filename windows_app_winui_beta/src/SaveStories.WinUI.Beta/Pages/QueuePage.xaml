<Page
    x:Class="SaveMe.WinUI.Beta.Pages.QueuePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer HorizontalScrollMode="Disabled" HorizontalScrollBarVisibility="Disabled">
        <Grid Padding="24,16,24,24" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="12">
                <Border Style="{StaticResource AppCardBorderStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="Очередь профилей" />
                        <TextBlock Style="{StaticResource AppSecondaryTextStyle}" Text="Пакетная выгрузка stories списком профилей." />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource AppCardBorderStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="ДОБАВИТЬ ПРОФИЛИ" />
                        <TextBox
                            x:Name="QueueInputTextBox"
                            AcceptsReturn="True"
                            MinHeight="160"
                            PlaceholderText="По одному username или ссылке на строку." />
                        <Grid ColumnSpacing="8" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Button Grid.Row="0" Grid.Column="0" HorizontalAlignment="Stretch" Click="OnAddProfilesClick" Content="Добавить" />
                            <Button Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch" Click="OnClearInputClick" Content="Очистить ввод" />
                            <Button Grid.Row="0" Grid.Column="2" HorizontalAlignment="Stretch" Click="OnCheckSessionClick" Content="Проверить сессию" />
                            <Button x:Name="RunQueueButton" Grid.Row="1" Grid.Column="0" HorizontalAlignment="Stretch" Click="OnRunQueueClick" Content="Скачать очередь" />
                            <Button x:Name="StopQueueButton" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch" Click="OnStopQueueClick" Content="Остановить" IsEnabled="False" />
                            <Button Grid.Row="1" Grid.Column="2" HorizontalAlignment="Stretch" Click="OnClearQueueClick" Content="Очистить очередь" />
                            <Button x:Name="RetryFailedQueueButton" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" HorizontalAlignment="Stretch" Click="OnRetryFailedClick" Content="Повторить неудачные" IsEnabled="False" />
                        </Grid>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="QueueSummaryText" Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource AppSecondaryTextStyle}" Text="Очередь: 0 профилей." />
                            <Button Grid.Column="1" Click="OnClearQueueClick" Content="Очистить список профилей" />
                        </Grid>
                        <ListView x:Name="QueueListView" MaxHeight="180" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="12">
                <Border Style="{StaticResource AppCardBorderStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="СОСТОЯНИЕ" />
                        <TextBlock x:Name="QueueStatusTitleText" Text="Ожидание" />
                        <TextBlock x:Name="QueueStatusDetailText" Style="{StaticResource AppSecondaryTextStyle}" Text="Готово к запуску очереди." />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource AppCardBorderStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="РЕЗУЛЬТАТ" />
                        <TextBlock x:Name="QueueResultSummaryText" Style="{StaticResource AppSecondaryTextStyle}" Text="Профилей: 0  ·  Найдено: 0  ·  Сохранено: 0" />
                    </StackPanel>
                </Border>

                <Expander Header="Диагностика и логи" IsExpanded="False">
                    <Border Style="{StaticResource AppCardBorderStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="ЛОГИ" />
                            <TextBox
                                x:Name="QueueLogsTextBox"
                                AcceptsReturn="True"
                                MinHeight="220"
                                IsReadOnly="True"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Expander>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
