<Page
    x:Class="SaveMe.WinUI.Beta.Pages.QueuePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer HorizontalScrollMode="Disabled" HorizontalScrollBarVisibility="Disabled">
        <Grid Padding="24,16,24,24" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="12">
                <Border Style="{StaticResource AppCardBorderStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="Очередь профилей" />
                        <TextBlock Style="{StaticResource AppSecondaryTextStyle}" Text="Пакетная выгрузка stories списком профилей." />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource AppCardBorderStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="ДОБАВИТЬ ПРОФИЛИ" />
                        <TextBox
                            x:Name="QueueInputTextBox"
                            AcceptsReturn="True"
                            MinHeight="160"
                            PlaceholderText="По одному username или ссылке на строку." />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Click="OnAddProfilesClick" Content="Добавить в очередь" />
                            <Button Click="OnClearInputClick" Content="Очистить" />
                            <Button Click="OnCheckSessionClick" Content="Проверить сессию" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="RunQueueButton" Click="OnRunQueueClick" Content="Скачать очередь" />
                            <Button x:Name="StopQueueButton" Click="OnStopQueueClick" Content="Остановить" IsEnabled="False" />
                            <Button x:Name="RetryFailedQueueButton" Click="OnRetryFailedClick" Content="Повторить неудачные" IsEnabled="False" />
                            <Button Click="OnClearQueueClick" Content="Очистить очередь" />
                        </StackPanel>
                        <TextBlock x:Name="QueueSummaryText" Style="{StaticResource AppSecondaryTextStyle}" Text="Очередь: 0 профилей." />
                        <ListView x:Name="QueueListView" MaxHeight="180" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="12">
                <Border Style="{StaticResource AppCardBorderStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="СОСТОЯНИЕ" />
                        <TextBlock x:Name="QueueStatusTitleText" Text="Ожидание" />
                        <TextBlock x:Name="QueueStatusDetailText" Style="{StaticResource AppSecondaryTextStyle}" Text="Готово к запуску очереди." />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource AppCardBorderStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="РЕЗУЛЬТАТ" />
                        <TextBlock x:Name="QueueResultSummaryText" Style="{StaticResource AppSecondaryTextStyle}" Text="Профилей: 0  ·  Найдено: 0  ·  Сохранено: 0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource AppCardBorderStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="ЛОГИ" />
                        <TextBox
                            x:Name="QueueLogsTextBox"
                            AcceptsReturn="True"
                            MinHeight="220"
                            IsReadOnly="True"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
