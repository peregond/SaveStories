<Page
    x:Class="SaveMe.WinUI.Beta.Pages.ReelsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer HorizontalScrollMode="Disabled" HorizontalScrollBarVisibility="Disabled">
        <Grid Padding="24,16,24,24" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="12">
                <Border Style="{StaticResource AppCardBorderStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="Reels" />
                        <TextBlock Style="{StaticResource AppSecondaryTextStyle}" Text="Скачать Reels по ссылке" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource AppCardBorderStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="ССЫЛКИ НА REELS" />
                        <TextBox
                            x:Name="ReelsInputTextBox"
                            AcceptsReturn="True"
                            MinHeight="160"
                            PlaceholderText="Вставь ссылки на Reels, по одной на строку." />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Click="OnAddLinksClick" Content="Добавить" />
                            <Button Click="OnClearInputClick" Content="Очистить" />
                            <Button Click="OnCheckSessionClick" Content="Проверить сессию" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="RunReelsButton" Click="OnDownloadClick" Content="Скачать" Style="{StaticResource SuccessActionButtonStyle}" />
                            <Button x:Name="StopReelsButton" Click="OnStopClick" Content="Остановить" IsEnabled="False" Style="{StaticResource DangerActionButtonStyle}" />
                            <Button x:Name="RetryFailedReelsButton" Click="OnRetryFailedClick" Content="Повторить неудачные" IsEnabled="False" />
                        </StackPanel>
                        <TextBlock x:Name="ReelsQueueSummaryText" Style="{StaticResource AppSecondaryTextStyle}" Text="Очередь: 0 ссылок." />
                        <ListView x:Name="ReelsQueueListView" MaxHeight="160" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Column="1" Style="{StaticResource AppCardBorderStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="СОСТОЯНИЕ" />
                    <TextBlock x:Name="ReelsStatusTitleText" Text="Ожидание" />
                    <TextBlock x:Name="ReelsStatusDetailText" Style="{StaticResource AppSecondaryTextStyle}" Text="Готово к запуску выгрузки Reels." />

                    <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="РЕЗУЛЬТАТ" />
                    <TextBlock x:Name="ReelsResultSummaryText" Style="{StaticResource AppSecondaryTextStyle}" Text="Ссылок: 0  ·  Сохранено: 0  ·  Файлов: 0" />

                    <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="ПОСЛЕДНИЕ ЗАГРУЗКИ" />
                    <ListView x:Name="ReelsDownloadsListView" MaxHeight="140" />

                    <Expander Header="Диагностика и логи" IsExpanded="False">
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="ЛОГИ" />
                            <TextBox
                                x:Name="ReelsLogsTextBox"
                                AcceptsReturn="True"
                                MinHeight="180"
                                IsReadOnly="True"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
