<Page
    x:Class="SaveStories.WinUI.Beta.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="24,16,24,24">
        <StackPanel Spacing="12">
            <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="Настройки" />
                    <TextBlock Opacity="0.75" Text="Beta-страница. Сюда переедет полный settings flow из стабильной версии." />
                </StackPanel>
            </Border>

            <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock FontWeight="SemiBold" Text="Оформление" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="DarkThemeButton" Click="OnDarkThemeClick" Content="Тёмная" />
                        <Button x:Name="LightThemeButton" Click="OnLightThemeClick" Content="Светлая" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock FontWeight="SemiBold" Text="Chromium после установки" />
                    <TextBlock x:Name="ChromiumSummaryText" Opacity="0.75" Text="Инициализация..." />
                    <TextBlock x:Name="ChromiumPathText" Opacity="0.65" TextWrapping="WrapWholeWords" />
                    <ProgressBar x:Name="ChromiumProgressBar" IsIndeterminate="True" Visibility="Collapsed" />
                    <TextBlock x:Name="ChromiumStatusText" Opacity="0.85" TextWrapping="WrapWholeWords" />
                    <TextBox
                        x:Name="ChromiumLogText"
                        MinHeight="100"
                        AcceptsReturn="True"
                        IsReadOnly="True"
                        TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="InstallChromiumButton" Click="OnInstallChromiumClick" Content="Установить Chromium" />
                        <Button Click="OnOpenChromiumFolderClick" Content="Открыть папку" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>
