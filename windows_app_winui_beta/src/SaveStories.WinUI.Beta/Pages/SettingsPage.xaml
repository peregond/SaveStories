<Page
    x:Class="SaveMe.WinUI.Beta.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer HorizontalScrollMode="Disabled" HorizontalScrollBarVisibility="Disabled">
        <Grid Padding="24,16,24,24">
            <StackPanel Spacing="12">
                <Border Style="{StaticResource AppCardBorderStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="Настройки" />
                        <TextBlock Style="{StaticResource AppSecondaryTextStyle}" Text="Параметры приложения, обновления и runtime-модули." />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource AppCardBorderStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="ОФОРМЛЕНИЕ" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="SystemThemeButton" Click="OnSystemThemeClick" Content="Системная" />
                            <Button x:Name="LightThemeButton" Click="OnLightThemeClick" Content="Светлая" />
                            <Button x:Name="DarkThemeButton" Click="OnDarkThemeClick" Content="Тёмная" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource AppCardBorderStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="ОБНОВЛЕНИЯ" />
                        <TextBlock x:Name="UpdateSummaryText" Style="{StaticResource AppSecondaryTextStyle}" TextWrapping="WrapWholeWords" />
                        <ProgressBar x:Name="UpdateProgressBar" IsIndeterminate="False" Minimum="0" Maximum="100" Visibility="Collapsed" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="CheckUpdatesButton" Click="OnCheckUpdatesClick" Content="Проверить обновления" />
                            <Button x:Name="DownloadUpdateButton" Click="OnDownloadUpdateClick" Content="Скачать обновление" IsEnabled="False" />
                            <Button x:Name="ApplyUpdateButton" Click="OnApplyUpdateClick" Content="Установить обновление" IsEnabled="False" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource AppCardBorderStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="ПРОВЕРКА ГОТОВНОСТИ" />
                        <TextBlock x:Name="PreflightSummaryText" Style="{StaticResource AppSecondaryTextStyle}" Text="Проверка ещё не запускалась." />
                        <TextBox
                            x:Name="PreflightDetailsTextBox"
                            MinHeight="80"
                            AcceptsReturn="True"
                            IsReadOnly="True"
                            TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Click="OnRunPreflightClick" Content="Проверить готовность" />
                            <Button Click="OnExportDiagnosticsClick" Content="Экспорт диагностики" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource AppCardBorderStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="RUNTIME МОДУЛИ ПОСЛЕ УСТАНОВКИ" />
                        <TextBlock x:Name="ChromiumSummaryText" Style="{StaticResource AppSecondaryTextStyle}" Text="Инициализация..." />
                        <TextBlock x:Name="ChromiumPathText" Opacity="0.65" TextWrapping="WrapWholeWords" />
                        <ProgressBar x:Name="ChromiumProgressBar" IsIndeterminate="True" Visibility="Collapsed" />
                        <TextBlock x:Name="ChromiumStatusText" Opacity="0.85" TextWrapping="WrapWholeWords" />
                        <TextBox
                            x:Name="ChromiumLogText"
                            MinHeight="100"
                            AcceptsReturn="True"
                            IsReadOnly="True"
                            TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="InstallChromiumButton" Click="OnInstallChromiumClick" Content="Докачать модули" />
                            <Button Click="OnOpenChromiumFolderClick" Content="Открыть папку" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
