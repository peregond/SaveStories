<Page
    x:Class="SaveMe.WinUI.Beta.Pages.StoriesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer HorizontalScrollMode="Disabled" HorizontalScrollBarVisibility="Disabled">
        <Grid Padding="24,16,24,24" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="12">
                <Border Style="{StaticResource AppCardBorderStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="Stories" />
                        <TextBlock Style="{StaticResource AppSecondaryTextStyle}" Text="Скачать сторис из Instagram" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource AppCardBorderStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="ПРОФИЛИ ДЛЯ СКАЧИВАНИЯ" />
                        <TextBox
                            x:Name="ProfilesInputTextBox"
                            AcceptsReturn="True"
                            MinHeight="160"
                            PlaceholderText="По одному username или ссылке на строку." />
                        <Border Style="{StaticResource AppCardBorderStyle}" Padding="10">
                            <StackPanel Spacing="8">
                                <ToggleSwitch
                                    x:Name="NotionInfluencerToggle"
                                    Header="Обновлять очередь из Notion"
                                    OffContent="Выключено"
                                    OnContent="Включено"
                                    Toggled="OnNotionInfluencerToggleToggled" />
                                <TextBlock
                                    Text="Перед запуском Stories приложение заново скачает список инфлюенсеров и заменит очередь."
                                    Style="{StaticResource AppSecondaryTextStyle}"
                                    TextWrapping="WrapWholeWords" />
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        x:Name="NotionInfluencerSummaryText"
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource AppSecondaryTextStyle}"
                                        Text="Автосписок Notion выключен."
                                        TextWrapping="WrapWholeWords" />
                                    <Button
                                        x:Name="RefreshNotionInfluencersButton"
                                        Grid.Column="1"
                                        Click="OnRefreshNotionInfluencersClick"
                                        Content="Обновить" />
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Grid ColumnSpacing="8" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Button Grid.Row="0" Grid.Column="0" HorizontalAlignment="Stretch" Click="OnAddProfilesClick" Content="Добавить" />
                            <Button Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch" Click="OnClearInputClick" Content="Очистить ввод" />
                            <Button Grid.Row="0" Grid.Column="2" HorizontalAlignment="Stretch" Click="OnCheckSessionClick" Content="Проверить сессию" />
                            <Button x:Name="DownloadButton" Grid.Row="1" Grid.Column="0" HorizontalAlignment="Stretch" Click="OnDownloadClick" Content="Скачать" Style="{StaticResource SuccessActionButtonStyle}" />
                            <Button x:Name="CancelButton" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch" Click="OnStopClick" Content="Остановить" IsEnabled="False" Style="{StaticResource DangerActionButtonStyle}" />
                            <Button Grid.Row="1" Grid.Column="2" HorizontalAlignment="Stretch" Click="OnClearQueueClick" Content="Очистить очередь" />
                            <Button x:Name="RetryFailedButton" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" HorizontalAlignment="Stretch" Click="OnRetryFailedClick" Content="Повторить неудачные" IsEnabled="False" />
                        </Grid>

                        <Border Style="{StaticResource AppCardBorderStyle}" Padding="10">
                            <StackPanel Spacing="8">
                                <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="РЕЖИМ БРАУЗЕРА" />
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <RadioButton
                                        x:Name="HeadlessModeRadio"
                                        GroupName="BrowserMode"
                                        Checked="OnBrowserModeChecked"
                                        Content="В фоне" />
                                    <RadioButton
                                        x:Name="VisibleModeRadio"
                                        GroupName="BrowserMode"
                                        Checked="OnBrowserModeChecked"
                                        Content="Видимо" />
                                </StackPanel>
                                <TextBlock
                                    x:Name="BrowserModeDescriptionText"
                                    Style="{StaticResource AppSecondaryTextStyle}"
                                    Text="Браузер скрыт, работает незаметно" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource AppCardBorderStyle}" Padding="10">
                            <StackPanel Spacing="8">
                                <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="ЧТО СОХРАНЯТЬ" />
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <RadioButton
                                        x:Name="SaveAllMediaRadio"
                                        GroupName="MediaMode"
                                        Checked="OnMediaModeChecked"
                                        Content="Фото и видео" />
                                    <RadioButton
                                        x:Name="SaveVideoOnlyRadio"
                                        GroupName="MediaMode"
                                        Checked="OnMediaModeChecked"
                                        Content="Только видео" />
                                </StackPanel>
                                <TextBlock
                                    x:Name="MediaModeDescriptionText"
                                    Style="{StaticResource AppSecondaryTextStyle}"
                                    Text="Фото пропускаются" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource AppCardBorderStyle}" Padding="10">
                            <StackPanel Spacing="8">
                                <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="ПАПКА СОХРАНЕНИЯ" />
                                <TextBlock
                                    x:Name="OutputDirectoryText"
                                    Style="{StaticResource AppSecondaryTextStyle}"
                                    TextWrapping="WrapWholeWords" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button x:Name="ChangeOutputDirectoryButton" Click="OnChangeOutputDirectoryClick" Content="Изменить папку" />
                                    <Button x:Name="OpenOutputDirectoryButton" Click="OnOpenOutputDirectoryClick" Content="Открыть папку" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="СПИСОК ПРОФИЛЕЙ ДЛЯ ВЫГРУЗКИ" />
                                <TextBlock x:Name="QueueSummaryText" Style="{StaticResource AppSecondaryTextStyle}" Text="Очередь: 0 профилей." />
                            </StackPanel>
                            <Button Grid.Column="1" VerticalAlignment="Center" Click="OnClearQueueClick" Content="Очистить список профилей" />
                        </Grid>
                        <ListView x:Name="QueueListView" MaxHeight="160" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="12">
                <Border Style="{StaticResource AppCardBorderStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="СОСТОЯНИЕ" />
                        <TextBlock x:Name="StatusTitleText" Text="Ожидание" />
                        <TextBlock x:Name="StatusDetailText" Style="{StaticResource AppSecondaryTextStyle}" Text="Готово к проверке сессии и выгрузке." />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource AppCardBorderStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="РЕЗУЛЬТАТ" />
                        <TextBlock x:Name="ResultSummaryText" Style="{StaticResource AppSecondaryTextStyle}" Text="Профилей: 0  ·  Сохранено: 0  ·  Файлов: 0" />
                    </StackPanel>
                </Border>

                <Expander Header="Диагностика и логи" IsExpanded="False">
                    <Border Style="{StaticResource AppCardBorderStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="ЛОГИ" />
                            <TextBox
                                x:Name="LogsTextBox"
                                AcceptsReturn="True"
                                MinHeight="200"
                                IsReadOnly="True"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Expander>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
