<Page
    x:Class="SaveMe.WinUI.Beta.Pages.StoriesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer HorizontalScrollMode="Disabled" HorizontalScrollBarVisibility="Disabled">
        <Grid Padding="24,16,24,24" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="12">
                <Border Style="{StaticResource AppCardBorderStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="Stories" />
                        <TextBlock Style="{StaticResource AppSecondaryTextStyle}" Text="Скачать сторис из Instagram" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource AppCardBorderStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="ПРОФИЛИ ДЛЯ СКАЧИВАНИЯ" />
                        <TextBox
                            x:Name="ProfilesInputTextBox"
                            AcceptsReturn="True"
                            MinHeight="160"
                            PlaceholderText="По одному username или ссылке на строку." />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Click="OnAddProfilesClick" Content="Добавить" />
                            <Button Click="OnClearInputClick" Content="Очистить" />
                            <Button Click="OnCheckSessionClick" Content="Проверить сессию" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="DownloadButton" Click="OnDownloadClick" Content="Скачать" Style="{StaticResource SuccessActionButtonStyle}" />
                            <Button x:Name="CancelButton" Click="OnStopClick" Content="Остановить" IsEnabled="False" Style="{StaticResource DangerActionButtonStyle}" />
                            <Button x:Name="RetryFailedButton" Click="OnRetryFailedClick" Content="Повторить неудачные" IsEnabled="False" />
                        </StackPanel>

                        <Border Style="{StaticResource AppCardBorderStyle}" Padding="10">
                            <StackPanel Spacing="8">
                                <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="РЕЖИМ БРАУЗЕРА" />
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <RadioButton
                                        x:Name="HeadlessModeRadio"
                                        GroupName="BrowserMode"
                                        Checked="OnBrowserModeChecked"
                                        Content="В фоне" />
                                    <RadioButton
                                        x:Name="VisibleModeRadio"
                                        GroupName="BrowserMode"
                                        Checked="OnBrowserModeChecked"
                                        Content="Видимо" />
                                </StackPanel>
                                <TextBlock
                                    x:Name="BrowserModeDescriptionText"
                                    Style="{StaticResource AppSecondaryTextStyle}"
                                    Text="Браузер скрыт, работает незаметно" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource AppCardBorderStyle}" Padding="10">
                            <StackPanel Spacing="8">
                                <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="ЧТО СОХРАНЯТЬ" />
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <RadioButton
                                        x:Name="SaveAllMediaRadio"
                                        GroupName="MediaMode"
                                        Checked="OnMediaModeChecked"
                                        Content="Фото и видео" />
                                    <RadioButton
                                        x:Name="SaveVideoOnlyRadio"
                                        GroupName="MediaMode"
                                        Checked="OnMediaModeChecked"
                                        Content="Только видео" />
                                </StackPanel>
                                <TextBlock
                                    x:Name="MediaModeDescriptionText"
                                    Style="{StaticResource AppSecondaryTextStyle}"
                                    Text="Фото пропускаются" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource AppCardBorderStyle}" Padding="10">
                            <StackPanel Spacing="8">
                                <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="ПАПКА СОХРАНЕНИЯ" />
                                <TextBlock
                                    x:Name="OutputDirectoryText"
                                    Style="{StaticResource AppSecondaryTextStyle}"
                                    TextWrapping="WrapWholeWords" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Click="OnChangeOutputDirectoryClick" Content="Изменить папку" />
                                    <Button Click="OnOpenOutputDirectoryClick" Content="Открыть папку" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="СПИСОК ПРОФИЛЕЙ ДЛЯ ВЫГРУЗКИ" />
                        <TextBlock x:Name="QueueSummaryText" Style="{StaticResource AppSecondaryTextStyle}" Text="Очередь: 0 профилей." />
                        <ListView x:Name="QueueListView" MaxHeight="160" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="12">
                <Border Style="{StaticResource AppCardBorderStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="СОСТОЯНИЕ" />
                        <TextBlock x:Name="StatusTitleText" Text="Ожидание" />
                        <TextBlock x:Name="StatusDetailText" Style="{StaticResource AppSecondaryTextStyle}" Text="Готово к проверке сессии и выгрузке." />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource AppCardBorderStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="РЕЗУЛЬТАТ" />
                        <TextBlock x:Name="ResultSummaryText" Style="{StaticResource AppSecondaryTextStyle}" Text="Профилей: 0  ·  Сохранено: 0  ·  Файлов: 0" />
                    </StackPanel>
                </Border>

                <Expander Header="Диагностика и логи" IsExpanded="False">
                    <Border Style="{StaticResource AppCardBorderStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource AppSectionHeaderTextStyle}" Text="ЛОГИ" />
                            <TextBox
                                x:Name="LogsTextBox"
                                AcceptsReturn="True"
                                MinHeight="200"
                                IsReadOnly="True"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Expander>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
