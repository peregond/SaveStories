<Application
    x:Class="SaveMe.WinUI.Beta.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <muxc:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <LinearGradientBrush x:Key="AppWindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0" Color="#FFF2F9E2" />
                        <GradientStop Offset="0.55" Color="#FFEFF7DF" />
                        <GradientStop Offset="1" Color="#FFE3F1C8" />
                    </LinearGradientBrush>
                    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="#CCFFFFFF" />
                    <SolidColorBrush x:Key="NavPaneBackgroundBrush" Color="#C7EEF4DE" />
                    <SolidColorBrush x:Key="SuccessActionBackgroundBrush" Color="#107C10" />
                    <SolidColorBrush x:Key="SuccessActionForegroundBrush" Color="#FFFFFFFF" />
                    <SolidColorBrush x:Key="DangerActionBackgroundBrush" Color="#C42B1C" />
                    <SolidColorBrush x:Key="DangerActionForegroundBrush" Color="#FFFFFFFF" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <LinearGradientBrush x:Key="AppWindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0" Color="#FF172116" />
                        <GradientStop Offset="0.55" Color="#FF182017" />
                        <GradientStop Offset="1" Color="#FF2D4A1B" />
                    </LinearGradientBrush>
                    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="#CC252A25" />
                    <SolidColorBrush x:Key="NavPaneBackgroundBrush" Color="#B61A2318" />
                    <SolidColorBrush x:Key="SuccessActionBackgroundBrush" Color="#1F8A4C" />
                    <SolidColorBrush x:Key="SuccessActionForegroundBrush" Color="#FFFFFFFF" />
                    <SolidColorBrush x:Key="DangerActionBackgroundBrush" Color="#B13A3A" />
                    <SolidColorBrush x:Key="DangerActionForegroundBrush" Color="#FFFFFFFF" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Default">
                    <LinearGradientBrush x:Key="AppWindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0" Color="#FF172116" />
                        <GradientStop Offset="0.55" Color="#FF182017" />
                        <GradientStop Offset="1" Color="#FF2D4A1B" />
                    </LinearGradientBrush>
                    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="#CC252A25" />
                    <SolidColorBrush x:Key="NavPaneBackgroundBrush" Color="#B61A2318" />
                    <SolidColorBrush x:Key="SuccessActionBackgroundBrush" Color="#1F8A4C" />
                    <SolidColorBrush x:Key="SuccessActionForegroundBrush" Color="#FFFFFFFF" />
                    <SolidColorBrush x:Key="DangerActionBackgroundBrush" Color="#B13A3A" />
                    <SolidColorBrush x:Key="DangerActionForegroundBrush" Color="#FFFFFFFF" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <SolidColorBrush x:Key="CardStrokeBrush" Color="#33FFFFFF" />

            <Style x:Key="AppCardBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource CardStrokeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="16" />
            </Style>

            <Style x:Key="AppSectionHeaderTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="CharacterSpacing" Value="120" />
                <Setter Property="TextWrapping" Value="WrapWholeWords" />
                <Setter Property="Opacity" Value="0.8" />
            </Style>

            <Style x:Key="AppSecondaryTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Opacity" Value="0.75" />
                <Setter Property="TextWrapping" Value="WrapWholeWords" />
            </Style>

            <Style TargetType="Button">
                <Setter Property="MinHeight" Value="32" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Padding" Value="12,6" />
            </Style>

            <Style x:Key="SuccessActionButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="Background" Value="{ThemeResource SuccessActionBackgroundBrush}" />
                <Setter Property="Foreground" Value="{ThemeResource SuccessActionForegroundBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource SuccessActionBackgroundBrush}" />
            </Style>

            <Style x:Key="DangerActionButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="Background" Value="{ThemeResource DangerActionBackgroundBrush}" />
                <Setter Property="Foreground" Value="{ThemeResource DangerActionForegroundBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource DangerActionBackgroundBrush}" />
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="CornerRadius" Value="4" />
            </Style>

            <Style TargetType="ListView">
                <Setter Property="CornerRadius" Value="6" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
