<Application
    x:Class="SaveMe.WinUI.Beta.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <muxc:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <LinearGradientBrush x:Key="AppWindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0" Color="#FFF5F8EF" />
                        <GradientStop Offset="0.55" Color="#FFF2F4EE" />
                        <GradientStop Offset="1" Color="#FFEAF3DB" />
                    </LinearGradientBrush>
                    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="#CCFFFFFF" />
                    <SolidColorBrush x:Key="NavPaneBackgroundBrush" Color="#BFF3F6ED" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <LinearGradientBrush x:Key="AppWindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0" Color="#FF141A14" />
                        <GradientStop Offset="0.55" Color="#FF141616" />
                        <GradientStop Offset="1" Color="#FF1D2B13" />
                    </LinearGradientBrush>
                    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="#CC252A25" />
                    <SolidColorBrush x:Key="NavPaneBackgroundBrush" Color="#B3141914" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Default">
                    <LinearGradientBrush x:Key="AppWindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0" Color="#FF141A14" />
                        <GradientStop Offset="0.55" Color="#FF141616" />
                        <GradientStop Offset="1" Color="#FF1D2B13" />
                    </LinearGradientBrush>
                    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="#CC252A25" />
                    <SolidColorBrush x:Key="NavPaneBackgroundBrush" Color="#B3141914" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
